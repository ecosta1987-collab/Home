          },
          {
            id: "event_nuoto",
            title: "Nuoto insieme",
            category: "sport",
            eventType: "recurring",
            childIds: ["child_anna", "child_luca", "child_mia"],
            location: "Piscina comunale",
            date: "2026-09-12",
            startDate: "2026-09-12",
            endDate: "2027-06-26",
