          children,
          events
        };
      }

      function getActiveChildren() {
        return state.data.children.filter((child) => !child.archived);
      }

      function childById(id) {
        return state.data.children.find((child) => child.id === id);
      }

      function childrenForEvent(event) {
        return event.childIds.map(childById).filter(Boolean);
      }

      function timeLabel(eventOrOccurrence) {
        const event = eventOrOccurrence.event || eventOrOccurrence;
        const fixed = eventOrOccurrence.fixedTime || event.fixedTime;
        const windowTime = eventOrOccurrence.timeWindow || event.timeWindow;
        if (event.timeMode === "window" && windowTime) {
          return `Ingresso ${windowTime.entryStart || "?"}-${windowTime.entryEnd || "?"} · Uscita ${windowTime.exitStart || "?"}-${windowTime.exitEnd || "?"}`;
        }
        if (fixed?.start || fixed?.end) return `${fixed.start || "?"}-${fixed.end || "?"}`;
        return "Orario non indicato";
      }

      function eventAccent(event) {
        const first = childrenForEvent(event)[0];
        return normalizeColor(first?.color, "#0f766e");
      }

      function eventMatchesDate(event, dateISO) {
        if (event.archived) return false;
        if (event.eventType === "single") return event.date === dateISO;
        const date = parseISODate(dateISO);
        const start = parseISODate(event.startDate);
        const end = parseISODate(event.endDate || dateISO);
        if (!date || !start || date < start || (end && date > end)) return false;
        if (!event.weekdays.includes(date.getDay())) return false;
        return true;
      }

      function closureForDate(event, dateISO) {
        return event.closures.find((closure) => {
          if (closure.type === "date") return closure.date === dateISO;
          if (closure.type === "range") return closure.startDate <= dateISO && closure.endDate >= dateISO;
          return false;
        });
      }

      function exceptionForDate(event, dateISO) {
        return event.exceptions.find((exception) => exception.date === dateISO);
      }

      function occurrenceForDate(event, dateISO) {
        if (!eventMatchesDate(event, dateISO)) return null;
        const closure = closureForDate(event, dateISO);
        if (closure) return null;
        const exception = exceptionForDate(event, dateISO);
        if (exception?.type === "cancelled") return null;
        return {
          id: `${event.id}_${dateISO}`,
          event,
          eventId: event.id,
          date: dateISO,
          fixedTime: exception?.fixedTime || event.fixedTime,
          timeWindow: exception?.timeWindow || event.timeWindow,
          exceptionNote: exception?.note || "",
          changed: Boolean(exception)
        };
      }

      function occurrencesBetween(startDate, endDate, options = {}) {
        const start = typeof startDate === "string" ? parseISODate(startDate) : startDate;
        const end = typeof endDate === "string" ? parseISODate(endDate) : endDate;
        const childId = options.childId || "all";
        const category = options.category || "all";
        const eventType = options.eventType || "all";
        const occurrences = [];
        for (let cursor = new Date(start); cursor <= end; cursor = addDays(cursor, 1)) {
          const dateISO = toISODate(cursor);
          state.data.events.forEach((event) => {
            if (childId !== "all" && !event.childIds.includes(childId)) return;
            if (category !== "all" && event.category !== category) return;
            if (eventType !== "all" && event.eventType !== eventType) return;
            const occurrence = occurrenceForDate(event, dateISO);
            if (occurrence) occurrences.push(occurrence);
          });
        }
        return occurrences.sort(compareOccurrences);
      }

      function compareOccurrences(a, b) {
        const dateCompare = a.date.localeCompare(b.date);
        if (dateCompare) return dateCompare;
        const aTime = a.fixedTime?.start || a.timeWindow?.entryStart || "99:99";
        const bTime = b.fixedTime?.start || b.timeWindow?.entryStart || "99:99";
        return aTime.localeCompare(bTime) || a.event.title.localeCompare(b.event.title);
      }

      function upcomingChanges(days = 45) {
        const today = todayISO();
        const end = toISODate(addDays(new Date(), days));
        const changes = [];
        state.data.events.filter((event) => !event.archived).forEach((event) => {
          [
            { date: event.startDate, label: "Inizio attività" },
            { date: event.endDate, label: "Fine attività" }
          ].forEach((item) => {
            if (item.date && item.date >= today && item.date <= end) {
              changes.push({ date: item.date, title: event.title, detail: item.label, event });
            }
          });
          if (event.eventType === "single" && event.date >= today && event.date <= end) {
            changes.push({ date: event.date, title: event.title, detail: "Evento singolo", event });
          }
          event.closures.forEach((closure) => {
            const date = closure.type === "date" ? closure.date : closure.startDate;
            if (date && date >= today && date <= end) {
              changes.push({ date, title: event.title, detail: closure.reason || "Chiusura", event });
            }
          });
          event.exceptions.forEach((exception) => {
            if (exception.date >= today && exception.date <= end) {
              changes.push({
                date: exception.date,
                title: event.title,
                detail: exception.type === "cancelled" ? "Annullato" : (exception.note || "Variazione orario"),
                event
              });
            }
          });
        });
        return changes.sort((a, b) => a.date.localeCompare(b.date)).slice(0, 8);
      }

      function renderTabs() {
        els.tabs.innerHTML = VIEWS.map((view) => `
          <button class="tab" type="button" data-view="${view.id}" aria-selected="${state.view === view.id}">
            ${escapeHtml(view.label)}
          </button>
        `).join("");
        els.tabs.querySelectorAll(".tab").forEach((tab) => {
          tab.addEventListener("click", () => {
            state.view = tab.dataset.view;
            render();
            els.app.focus();
          });
        });
      }

      function render() {
        renderTabs();
        const renderers = {
          home: renderHome,
          week: renderWeek,
          agenda: renderAgenda,
          children: renderChildren,
          events: renderEvents,
          data: renderData
        };
        els.app.innerHTML = renderers[state.view]();
        bindViewActions();
      }

      function viewHeader(title, text, action = "") {
        return `
          <div class="view-head">
            <div>
              <h2>${escapeHtml(title)}</h2>
              <p class="subtitle">${escapeHtml(text)}</p>
            </div>
            ${action}
          </div>
        `;
      }

      function renderHome() {
        const today = todayISO();
        const weekStart = startOfWeek(new Date());
        const weekEnd = addDays(weekStart, 6);
        const todayItems = occurrencesBetween(today, today);
        const weekItems = occurrencesBetween(weekStart, weekEnd).slice(0, 7);
        const changes = upcomingChanges();
        return `
          ${viewHeader("Home", "Tre cose da guardare: oggi, settimana, cambiamenti.")}
          <div class="grid-3">
            <section class="section">
              <h3>Oggi</h3>
              <div class="stack">${renderOccurrenceList(todayItems, "Nessun impegno per oggi.")}</div>
            </section>
            <section class="section">
              <h3>Questa settimana</h3>
              <div class="stack">${renderOccurrenceList(weekItems, "Nessun impegno questa settimana.")}</div>
            </section>
            <section class="section">
              <h3>Prossimi cambiamenti</h3>
              <div class="stack">${changes.length ? changes.map(renderChange).join("") : `<div class="empty">Nessun cambiamento imminente.</div>`}</div>
            </section>
          </div>
        `;
      }

      function renderWeek() {
        const start = state.weekStart;
        const end = addDays(start, 6);
        const items = occurrencesBetween(start, end, { childId: state.filters.childId });
        const groups = groupBy(items, "date");
        return `
          ${viewHeader("Vista settimana", `${formatDate(start, { year: true })} - ${formatDate(end, { year: true })}`)}
          <div class="week-nav">
            <div class="row">
              <button class="button secondary small" type="button" data-week-move="-7">← Settimana prima</button>
              <button class="button secondary small" type="button" data-week-today="true">Oggi</button>
              <button class="button secondary small" type="button" data-week-move="7">Settimana dopo →</button>
            </div>
            <label>
              Filtra per figlio
              <select data-filter-child>
                ${renderChildOptions(state.filters.childId, true)}
              </select>
            </label>
          </div>
          <div class="stack">
            ${Array.from({ length: 7 }, (_, index) => {
              const date = toISODate(addDays(start, index));
              const dayItems = groups[date] || [];
              return `
                <section class="day-group">
                  <h3 class="day-title">${formatDate(date, { weekday: true, year: true })}</h3>
                  ${renderOccurrenceList(dayItems, "Nessun impegno.")}
                </section>
              `;
            }).join("")}
          </div>
        `;
      }

      function renderAgenda() {
        const start = new Date();
        const end = addDays(start, 90);
        const items = occurrencesBetween(start, end, { childId: state.filters.childId });
        const groups = groupBy(items, "date");
        return `
          ${viewHeader("Agenda", "Elenco cronologico dei prossimi 90 giorni.")}
          <div class="filters">
            <label>
              Figlio
              <select data-filter-child>${renderChildOptions(state.filters.childId, true)}</select>
            </label>
          </div>
          <div>
            ${items.length ? Object.keys(groups).map((date) => `
              <section class="day-group">
                <h3 class="day-title">${formatDate(date, { weekday: true, year: true })}</h3>
                ${renderOccurrenceList(groups[date], "")}
              </section>
            `).join("") : `<div class="empty">Nessun impegno futuro.</div>`}
          </div>
        `;
      }

      function renderChildren() {
        const children = state.data.children;
        return `
          ${viewHeader("Figli", "Anagrafica, colori e impegni collegati.", `<button class="button" type="button" data-add-child>+ Aggiungi figlio</button>`)}
          <div class="grid-2">
            ${children.length ? children.map(renderChildCard).join("") : `<div class="empty">Aggiungi il primo figlio.</div>`}
          </div>
        `;
      }

      function renderEvents() {
        const filtered = state.data.events.filter((event) => {
          if (state.filters.category !== "all" && event.category !== state.filters.category) return false;
          if (state.filters.eventType !== "all" && event.eventType !== state.filters.eventType) return false;
          if (state.filters.childId !== "all" && !event.childIds.includes(state.filters.childId)) return false;
          return true;
        });
        return `
          ${viewHeader("Impegni", "Crea, modifica, duplica, archivia o elimina.", `<button class="button" type="button" data-add-event>+ Aggiungi impegno</button>`)}
          <div class="filters">
            <label>Categoria
              <select data-filter-category>
                <option value="all">Tutte</option>
                ${CATEGORIES.map((cat) => `<option value="${cat}" ${state.filters.category === cat ? "selected" : ""}>${cat}</option>`).join("")}
              </select>
            </label>
            <label>Figlio
              <select data-filter-child>${renderChildOptions(state.filters.childId, true)}</select>
            </label>
            <label>Tipologia
              <select data-filter-type>
                <option value="all">Tutte</option>
                ${EVENT_TYPES.map((type) => `<option value="${type.value}" ${state.filters.eventType === type.value ? "selected" : ""}>${type.label}</option>`).join("")}
              </select>
            </label>
          </div>
          <div class="stack">
            ${filtered.length ? filtered.map((event) => renderEventManageCard(event)).join("") : `<div class="empty">Nessun impegno con questi filtri.</div>`}
          </div>
        `;
      }

      function renderData() {
        const payload = JSON.stringify(exportPayload(), null, 2);
        return `
          ${viewHeader("Dati", "Importa, esporta e gestisci il salvataggio locale.")}
          <div class="grid-2">
            <section class="section stack">
              <h3>Azioni</h3>
              <button class="button" type="button" data-export-current>Scarica JSON corrente</button>
              <button class="button secondary" type="button" data-export-sample>Scarica JSON di esempio</button>
              <label>
                Importa JSON
                <input type="file" accept="application/json,.json" data-import-file>
              </label>
              <button class="button warning" type="button" data-load-sample>Carica esempio nell'app</button>
              <button class="button danger" type="button" data-clear-data>Cancella tutti i dati</button>
              <p class="inline-error" id="dataError" aria-live="assertive"></p>
            </section>
            <section class="section stack">
              <h3>Stato</h3>
              <p><strong>Schema JSON:</strong> versione ${SCHEMA_VERSION}</p>
              <p><strong>Salvataggio:</strong> localStorage, chiave <code>${STORAGE_KEY}</code></p>
              <p><strong>Ultimo salvataggio:</strong> ${state.data.lastSavedAt ? new Date(state.data.lastSavedAt).toLocaleString("it-IT") : "non ancora salvato"}</p>
              <details class="advanced">
                <summary>Anteprima JSON corrente</summary>
                <pre class="data-box">${escapeHtml(payload)}</pre>
              </details>
            </section>
          </div>
        `;
      }

      function renderOccurrenceList(items, emptyText) {
        if (!items.length) return emptyText ? `<div class="empty">${escapeHtml(emptyText)}</div>` : "";
        return items.map(renderOccurrenceCard).join("");
      }

      function renderOccurrenceCard(occurrence) {
        const event = occurrence.event;
        const childPills = childrenForEvent(event).map(renderChildPill).join("");
        const meal = event.mealOptions.length ? `<span class="badge">Pasti: ${event.mealOptions.map(escapeHtml).join(", ")}</span>` : "";
        const flags = [
          event.notes ? `<span class="badge">Note</span>` : "",
          event.packingList.length ? `<span class="badge">Checklist</span>` : "",
          occurrence.changed ? `<span class="badge">Variazione</span>` : ""
        ].join("");
        return `
          <article class="event-card" style="border-left-color:${eventAccent(event)}">
            <div class="event-title">
              <div>
                <h3>${escapeHtml(event.title)}</h3>
                <div class="meta">${escapeHtml(timeLabel(occurrence))}${event.location ? ` · ${escapeHtml(event.location)}` : ""}</div>
              </div>
              <span class="badge">${escapeHtml(event.category)}</span>
            </div>
            <div class="row">${childPills}</div>
            <div class="row">${meal}${flags}</div>
            ${occurrence.exceptionNote ? `<p class="meta"><strong>Eccezione:</strong> ${escapeHtml(occurrence.exceptionNote)}</p>` : ""}
            ${event.notes ? `<details class="advanced"><summary>Note</summary><p>${escapeHtml(event.notes)}</p></details>` : ""}
            ${event.packingList.length ? renderPackingChecklist(occurrence) : ""}
          </article>
        `;
      }

      function renderPackingChecklist(occurrence) {
        const key = `${occurrence.eventId}|${occurrence.date}`;
        const checked = state.tempChecklist[key] || {};
        return `
          <details class="advanced">
            <summary>Cose da portare</summary>
            <div class="packing-list" data-checklist-key="${key}">
              ${occurrence.event.packingList.map((item) => `
                <label class="checkline">
                  <input type="checkbox" data-temp-check="${item.id}" ${checked[item.id] ? "checked" : ""}>
                  ${escapeHtml(item.label)}
                </label>
              `).join("")}
            </div>
          </details>
        `;
      }

      function renderChange(change) {
        return `
          <article class="event-card" style="border-left-color:${eventAccent(change.event)}">
            <div class="event-title">
              <div>
                <h3>${escapeHtml(change.title)}</h3>
                <div class="meta">${formatDate(change.date, { weekday: true, year: true })}</div>
              </div>
            </div>
            <p class="meta">${escapeHtml(change.detail)}</p>
            <div class="row">${childrenForEvent(change.event).map(renderChildPill).join("")}</div>
          </article>
        `;
      }

      function renderChildPill(child) {
        return `
          <span class="child-pill">
            <span class="avatar" style="background:${normalizeColor(child.color)}">${escapeHtml(child.avatar || child.name[0] || "?")}</span>
            ${escapeHtml(child.name)}
          </span>
        `;
      }

      function renderChildCard(child) {
        const count = state.data.events.filter((event) => event.childIds.includes(child.id) && !event.archived).length;
        return `
          <article class="child-card ${child.archived ? "archived" : ""}">
            <div class="row spread">
              <div class="row">
                <span class="avatar" style="background:${normalizeColor(child.color)}">${escapeHtml(child.avatar)}</span>
                <div>
                  <h3 style="margin:0">${escapeHtml(child.name)}</h3>
                  <p class="meta" style="margin:0">${child.archived ? "Archiviato" : "Attivo"} · ${count} impegni</p>
                </div>
              </div>
            </div>
            ${child.notes ? `<p class="meta">${escapeHtml(child.notes)}</p>` : ""}
            <div class="row">
              <button class="button secondary small" type="button" data-edit-child="${child.id}">Modifica</button>
              <button class="button secondary small" type="button" data-toggle-child="${child.id}">${child.archived ? "Riattiva" : "Archivia"}</button>
            </div>
          </article>
        `;
      }

      function renderEventManageCard(event) {
        return `
          <article class="event-card ${event.archived ? "archived" : ""}" style="border-left-color:${eventAccent(event)}">
            <div class="event-title">
              <div>
                <h3>${escapeHtml(event.title)}</h3>
                <div class="meta">${eventTypeLabel(event.eventType)} · ${escapeHtml(event.category)} · ${event.archived ? "Archiviato" : "Attivo"}</div>
              </div>
              <span class="badge">${escapeHtml(timeLabel(event))}</span>
            </div>
            <div class="row">${childrenForEvent(event).map(renderChildPill).join("") || `<span class="meta">Nessun figlio collegato</span>`}</div>
            <div class="row">
              <button class="button secondary small" type="button" data-edit-event="${event.id}">Modifica</button>
              <button class="button secondary small" type="button" data-duplicate-event="${event.id}">Duplica</button>
              <button class="button secondary small" type="button" data-toggle-event="${event.id}">${event.archived ? "Riattiva" : "Archivia"}</button>
              <button class="button danger small" type="button" data-delete-event="${event.id}">Elimina</button>
            </div>
          </article>
        `;
      }

      function renderChildOptions(selected, includeAll = false) {
        return `${includeAll ? `<option value="all">Tutti</option>` : ""}${state.data.children.map((child) => `
          <option value="${child.id}" ${selected === child.id ? "selected" : ""}>${escapeHtml(child.name)}${child.archived ? " (archiviato)" : ""}</option>
        `).join("")}`;
      }

      function eventTypeLabel(type) {
        return EVENT_TYPES.find((item) => item.value === type)?.label || type;
      }

      function groupBy(items, key) {
        return items.reduce((acc, item) => {
          const value = item[key];
          acc[value] = acc[value] || [];
          acc[value].push(item);
          return acc;
        }, {});
      }

      function bindViewActions() {
        els.app.querySelectorAll("[data-add-child]").forEach((button) => button.addEventListener("click", () => openChildForm()));
        els.app.querySelectorAll("[data-add-event]").forEach((button) => button.addEventListener("click", () => openEventForm()));
        els.app.querySelectorAll("[data-edit-child]").forEach((button) => button.addEventListener("click", () => openChildForm(button.dataset.editChild)));
        els.app.querySelectorAll("[data-toggle-child]").forEach((button) => button.addEventListener("click", () => toggleChild(button.dataset.toggleChild)));
        els.app.querySelectorAll("[data-edit-event]").forEach((button) => button.addEventListener("click", () => openEventForm(button.dataset.editEvent)));
        els.app.querySelectorAll("[data-duplicate-event]").forEach((button) => button.addEventListener("click", () => duplicateEvent(button.dataset.duplicateEvent)));
        els.app.querySelectorAll("[data-toggle-event]").forEach((button) => button.addEventListener("click", () => toggleEvent(button.dataset.toggleEvent)));
        els.app.querySelectorAll("[data-delete-event]").forEach((button) => button.addEventListener("click", () => deleteEvent(button.dataset.deleteEvent)));
        els.app.querySelectorAll("[data-week-move]").forEach((button) => button.addEventListener("click", () => {
          state.weekStart = addDays(state.weekStart, Number(button.dataset.weekMove));
          render();
        }));
        els.app.querySelectorAll("[data-week-today]").forEach((button) => button.addEventListener("click", () => {
          state.weekStart = startOfWeek(new Date());
          render();
        }));
        els.app.querySelectorAll("[data-filter-child]").forEach((select) => select.addEventListener("change", () => {
          state.filters.childId = select.value;
          render();
        }));
        const category = els.app.querySelector("[data-filter-category]");
        if (category) category.addEventListener("change", () => { state.filters.category = category.value; render(); });
        const eventType = els.app.querySelector("[data-filter-type]");
        if (eventType) eventType.addEventListener("change", () => { state.filters.eventType = eventType.value; render(); });
        els.app.querySelectorAll("[data-temp-check]").forEach((checkbox) => {
          checkbox.addEventListener("change", () => {
            const key = checkbox.closest("[data-checklist-key]").dataset.checklistKey;
            state.tempChecklist[key] = state.tempChecklist[key] || {};
            state.tempChecklist[key][checkbox.dataset.tempCheck] = checkbox.checked;
          });
        });
        bindDataActions();
      }

      function bindDataActions() {
        const exportCurrent = els.app.querySelector("[data-export-current]");
        if (exportCurrent) exportCurrent.addEventListener("click", () => downloadJSON("agenda-figli.json", exportPayload()));
        const exportSample = els.app.querySelector("[data-export-sample]");
        if (exportSample) exportSample.addEventListener("click", () => downloadJSON("agenda-figli-esempio.json", makeSampleData()));
        const loadSample = els.app.querySelector("[data-load-sample]");
        if (loadSample) loadSample.addEventListener("click", () => {
          if (!confirm("Caricare l'esempio? I dati attuali saranno sovrascritti.")) return;
          state.data = migrateData(makeSampleData());
          saveData("Esempio caricato");
          render();
        });
        const clearData = els.app.querySelector("[data-clear-data]");
        if (clearData) clearData.addEventListener("click", () => {
          if (!confirm("Cancellare tutti i dati salvati su questo dispositivo?")) return;
          state.data = createEmptyData();
          state.tempChecklist = {};
          saveData("Dati cancellati");
          render();
        });
        const importInput = els.app.querySelector("[data-import-file]");
        if (importInput) importInput.addEventListener("change", handleImportFile);
      }

      function handleImportFile(event) {
        const errorEl = els.app.querySelector("#dataError");
        const file = event.target.files?.[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = () => {
          try {
            const parsed = JSON.parse(String(reader.result));
            const validation = validateImportedData(parsed);
            if (!validation.ok) {
              errorEl.textContent = `File non valido: ${validation.errors.join(" ")}`;
              event.target.value = "";
              return;
            }
            if (!confirm("Importare questo file e sovrascrivere i dati attuali?")) {
              event.target.value = "";
              return;
            }
            state.data = migrateData(parsed);
            state.tempChecklist = {};
            saveData("Importazione completata");
            render();
          } catch (error) {
            errorEl.textContent = "JSON non valido. I dati esistenti non sono stati modificati.";
            event.target.value = "";
          }
        };
        reader.readAsText(file);
      }

      function openModal(title, subtitle, html) {
        state.lastFocus = document.activeElement;
        els.modalTitle.textContent = title;
        els.modalSubtitle.textContent = subtitle || "";
        els.modalBody.innerHTML = html;
        els.modal.classList.add("open");
        els.modal.setAttribute("aria-hidden", "false");
        const first = els.modal.querySelector("button, input, select, textarea, summary");
        if (first) first.focus();
      }

      function closeModal() {
        els.modal.classList.remove("open");
        els.modal.setAttribute("aria-hidden", "true");
        els.modalBody.innerHTML = "";
        if (state.lastFocus?.focus) state.lastFocus.focus();
      }

      function trapModalFocus(event) {
        if (!els.modal.classList.contains("open") || event.key !== "Tab") return;
        const focusables = [...els.modal.querySelectorAll("button, input, select, textarea, summary")].filter((el) => !el.disabled && el.offsetParent !== null);
        if (!focusables.length) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }

      function openChildForm(childId) {
        const child = childById(childId) || {
          id: uid("child"),
          name: "",
          color: "#0f766e",
          avatar: "",
          notes: "",
          archived: false
        };
        openModal(childId ? "Modifica figlio" : "Aggiungi figlio", "Campi brevi, colore sempre accompagnato da nome o iniziale.", `
          <form id="childForm" class="stack">
            <div class="form-grid">
              <label>Nome
                <input name="name" required value="${escapeHtml(child.name)}">
              </label>
              <label>Colore
                <input name="color" type="color" value="${normalizeColor(child.color)}">
              </label>
              <label>Emoji o iniziale
                <input name="avatar" maxlength="2" value="${escapeHtml(child.avatar)}">
              </label>
              <label>Stato
                <select name="archived">
                  <option value="false" ${!child.archived ? "selected" : ""}>Attivo</option>
                  <option value="true" ${child.archived ? "selected" : ""}>Archiviato</option>
                </select>
              </label>
              <label class="full">Note
                <textarea name="notes">${escapeHtml(child.notes)}</textarea>
              </label>
            </div>
            <p class="inline-error" id="childError"></p>
            <div class="row">
              <button class="button" type="submit">Salva figlio</button>
              <button class="button secondary" type="button" data-cancel-modal>Annulla</button>
            </div>
          </form>
        `);
        const form = document.getElementById("childForm");
        form.addEventListener("submit", (event) => {
          event.preventDefault();
          const data = new FormData(form);
          const name = String(data.get("name") || "").trim();
          if (!name) {
            document.getElementById("childError").textContent = "Inserisci il nome.";
            return;
          }
          const nextChild = {
            id: child.id,
            name,
            color: normalizeColor(String(data.get("color") || "")),
            avatar: String(data.get("avatar") || name[0] || "?").trim().slice(0, 2),
            notes: String(data.get("notes") || "").trim(),
            archived: data.get("archived") === "true"
          };
          const index = state.data.children.findIndex((item) => item.id === child.id);
          if (index >= 0) state.data.children[index] = nextChild;
          else state.data.children.push(nextChild);
          saveData("Figlio salvato");
          closeModal();
          render();
        });
        els.modalBody.querySelector("[data-cancel-modal]").addEventListener("click", closeModal);
      }

      function openEventForm(eventId) {
        const existing = state.data.events.find((event) => event.id === eventId);
        const draft = normalizeEvent(existing || {
          id: uid("event"),
          title: "",
          category: "altro",
          eventType: "single",
          childIds: [],
          location: "",
          date: todayISO(),
          startDate: todayISO(),
          endDate: "",
          weekdays: [],
          timeMode: "fixed",
          fixedTime: { start: "", end: "" },
          timeWindow: null,
          mealOptions: [],
          notes: "",
          packingList: [],
          closures: [],
          exceptions: [],
          archived: false
        });
        let step = 0;
        const steps = [
          "Tipo", "Figli", "Quando", "Orario", "Pasti", "Note", "Eccezioni", "Riepilogo"
        ];
        openModal(existing ? "Modifica impegno" : "Aggiungi impegno", "Procedi a piccoli passi. I campi non utili restano nascosti.", `<form id="eventForm" class="stack"></form>`);
        const form = document.getElementById("eventForm");

        function currentFormData() {
          const data = new FormData(form);
          const hasField = (name) => Boolean(form.querySelector(`[name="${name}"]`));
          if (hasField("title")) draft.title = String(data.get("title") ?? draft.title).trim();
          if (hasField("category")) draft.category = String(data.get("category") ?? draft.category);
          if (hasField("eventType")) draft.eventType = String(data.get("eventType") ?? draft.eventType);
          if (hasField("childIds")) draft.childIds = data.getAll("childIds").map(String);
          if (hasField("location")) draft.location = String(data.get("location") ?? draft.location).trim();
          if (hasField("date")) draft.date = String(data.get("date") ?? draft.date);
          if (hasField("startDate")) draft.startDate = String(data.get("startDate") ?? draft.startDate);
          if (hasField("endDate")) draft.endDate = String(data.get("endDate") ?? draft.endDate);
          if (hasField("weekdays")) draft.weekdays = data.getAll("weekdays").map(Number);
          if (hasField("timeMode")) {
            draft.timeMode = String(data.get("timeMode") ?? draft.timeMode);
            if (draft.timeMode === "fixed") {
              draft.fixedTime = { start: String(data.get("fixedStart") || ""), end: String(data.get("fixedEnd") || "") };
              draft.timeWindow = null;
            } else {
              draft.fixedTime = null;
              draft.timeWindow = {
                entryStart: String(data.get("entryStart") || ""),
                entryEnd: String(data.get("entryEnd") || ""),
                exitStart: String(data.get("exitStart") || ""),
                exitEnd: String(data.get("exitEnd") || "")
              };
            }
          }
          if (hasField("mealOptions")) draft.mealOptions = data.getAll("mealOptions").map(String);
          if (hasField("notes")) draft.notes = String(data.get("notes") || "").trim();
          if (hasField("packingList")) draft.packingList = linesToItems(String(data.get("packingList") || ""), "item");
          if (hasField("closures")) draft.closures = parseClosures(String(data.get("closures") || ""));
          if (hasField("exceptions")) draft.exceptions = parseExceptions(String(data.get("exceptions") || ""));
          if (hasField("archived")) draft.archived = data.get("archived") === "true";
        }

        function renderStep() {
          form.innerHTML = `
            <div class="steps" aria-label="Passaggi">${steps.map((label, index) => `
              <span class="step-chip ${index === step ? "active" : ""}">${index + 1}. ${label}</span>
            `).join("")}</div>
            ${stepHtml()}
            <p class="inline-error" id="eventError" aria-live="assertive"></p>
            <div class="row spread">
              <div class="row">
                <button class="button secondary" type="button" data-prev-step ${step === 0 ? "disabled" : ""}>Indietro</button>
                ${step < steps.length - 1 ? `<button class="button" type="button" data-next-step>Avanti</button>` : `<button class="button" type="submit">Salva impegno</button>`}
              </div>
              <button class="button secondary" type="button" data-cancel-modal>Annulla</button>
            </div>
          `;
          bindEventStepControls();
        }

        function stepHtml() {
          if (step === 0) return `
            <div class="form-grid">
              <label class="full">Titolo
                <input name="title" required value="${escapeHtml(draft.title)}" placeholder="Es. Nuoto, scuola, visita">
              </label>
              <label>Categoria
                <select name="category">${CATEGORIES.map((cat) => `<option value="${cat}" ${draft.category === cat ? "selected" : ""}>${cat}</option>`).join("")}</select>
              </label>
              <label>Tipo di impegno
                <select name="eventType">${EVENT_TYPES.map((type) => `<option value="${type.value}" ${draft.eventType === type.value ? "selected" : ""}>${type.label}</option>`).join("")}</select>
              </label>
              <label>Stato
                <select name="archived">
                  <option value="false" ${!draft.archived ? "selected" : ""}>Attivo</option>
                  <option value="true" ${draft.archived ? "selected" : ""}>Archiviato</option>
                </select>
              </label>
            </div>
          `;
          if (step === 1) return `
            <div class="stack">
              <p class="subtitle">Seleziona uno o più figli. Un evento condiviso resta salvato una sola volta.</p>
              <div class="choice-list">
                ${state.data.children.length ? state.data.children.map((child) => `
                  <label class="checkline">
                    <input type="checkbox" name="childIds" value="${child.id}" ${draft.childIds.includes(child.id) ? "checked" : ""}>
                    <span class="avatar" style="background:${normalizeColor(child.color)}">${escapeHtml(child.avatar)}</span>
                    ${escapeHtml(child.name)}${child.archived ? " (archiviato)" : ""}
                  </label>
                `).join("") : `<div class="empty">Aggiungi prima almeno un figlio.</div>`}
              </div>
            </div>
          `;
          if (step === 2) return `
            <div class="form-grid">
              ${draft.eventType === "single" ? `
                <label>Data
                  <input type="date" name="date" value="${escapeHtml(draft.date)}">
                </label>
              ` : `
                <label>Data di inizio
                  <input type="date" name="startDate" value="${escapeHtml(draft.startDate)}">
                </label>
                <label>Data di fine
                  <input type="date" name="endDate" value="${escapeHtml(draft.endDate)}">
                </label>
                <div class="full">
                  <p class="subtitle">Giorni della settimana</p>
                  <div class="choice-list">
                    ${WEEKDAYS.map((day) => `
                      <label class="checkline">
                        <input type="checkbox" name="weekdays" value="${day.value}" ${draft.weekdays.includes(day.value) ? "checked" : ""}>
                        ${day.long}
                      </label>
                    `).join("")}
                  </div>
                </div>
              `}
              <label class="full">Luogo
                <input name="location" value="${escapeHtml(draft.location)}" placeholder="Facoltativo">
              </label>
            </div>
          `;
          if (step === 3) return `
            <div class="stack">
              <label>Modalità orario
                <select name="timeMode" data-time-mode>
                  <option value="fixed" ${draft.timeMode === "fixed" ? "selected" : ""}>Orario fisso</option>
                  <option value="window" ${draft.timeMode === "window" ? "selected" : ""}>Finestra possibile</option>
                </select>
              </label>
              <div class="form-grid" data-fixed-fields ${draft.timeMode === "window" ? "hidden" : ""}>
                <label>Ora inizio
                  <input type="time" name="fixedStart" value="${escapeHtml(draft.fixedTime?.start || "")}">
                </label>
                <label>Ora fine
                  <input type="time" name="fixedEnd" value="${escapeHtml(draft.fixedTime?.end || "")}">
                </label>
              </div>
              <div class="form-grid" data-window-fields ${draft.timeMode === "fixed" ? "hidden" : ""}>
                <label>Inizio ingresso
                  <input type="time" name="entryStart" value="${escapeHtml(draft.timeWindow?.entryStart || "")}">
                </label>
                <label>Fine ingresso
                  <input type="time" name="entryEnd" value="${escapeHtml(draft.timeWindow?.entryEnd || "")}">
                </label>
                <label>Inizio uscita
                  <input type="time" name="exitStart" value="${escapeHtml(draft.timeWindow?.exitStart || "")}">
                </label>
                <label>Fine uscita
                  <input type="time" name="exitEnd" value="${escapeHtml(draft.timeWindow?.exitEnd || "")}">
                </label>
              </div>
            </div>
          `;
          if (step === 4) return `
            <div class="stack">
              <p class="subtitle">Lascia vuoto se non rilevante.</p>
              ${MEALS.map((meal) => `
                <label class="checkline">
                  <input type="checkbox" name="mealOptions" value="${meal.value}" ${draft.mealOptions.includes(meal.value) ? "checked" : ""}>
                  ${meal.label}
                </label>
              `).join("")}
            </div>
          `;
          if (step === 5) return `
            <div class="form-grid">
              <label class="full">Note
                <textarea name="notes" placeholder="Informazioni utili, senza promemoria automatici.">${escapeHtml(draft.notes)}</textarea>
              </label>
              <label class="full">Cose da portare
                <textarea name="packingList" placeholder="Una voce per riga">${escapeHtml(draft.packingList.map((item) => item.label).join("\n"))}</textarea>
              </label>
            </div>
          `;
          if (step === 6) return `
            <div class="stack">
              <details class="advanced" ${draft.eventType !== "single" ? "open" : ""}>
                <summary>Chiusure</summary>
                <p class="subtitle">Una riga per chiusura: <code>data|motivo</code> oppure <code>inizio..fine|motivo</code>.</p>
                <label>Chiusure
                  <textarea name="closures" placeholder="2026-12-08|Festività&#10;2026-12-23..2027-01-06|Vacanze">${escapeHtml(formatClosures(draft.closures))}</textarea>
                </label>
              </details>
              <details class="advanced" ${draft.exceptions.length ? "open" : ""}>
                <summary>Eccezioni</summary>
                <p class="subtitle">Una riga: <code>data|annullato|nota</code> oppure <code>data|HH:MM-HH:MM|nota</code>.</p>
                <label>Eccezioni
                  <textarea name="exceptions" placeholder="2027-06-10|08:00-13:00|Uscita anticipata&#10;2027-03-13|annullato|Piscina chiusa">${escapeHtml(formatExceptions(draft.exceptions))}</textarea>
                </label>
              </details>
            </div>
          `;
          return `
            <div class="section stack">
              <h3>Riepilogo</h3>
              <p><strong>${escapeHtml(draft.title || "Senza titolo")}</strong></p>
              <p>${eventTypeLabel(draft.eventType)} · ${escapeHtml(draft.category)} · ${escapeHtml(timeLabel(draft))}</p>
              <div class="row">${draft.childIds.map(childById).filter(Boolean).map(renderChildPill).join("") || `<span class="meta">Nessun figlio selezionato</span>`}</div>
              <p class="meta">${escapeHtml(draft.location || "Luogo non indicato")}</p>
              <p class="meta">${draft.packingList.length} cose da portare · ${draft.closures.length} chiusure · ${draft.exceptions.length} eccezioni</p>
            </div>
          `;
        }

        function bindEventStepControls() {
          form.querySelector("[data-cancel-modal]")?.addEventListener("click", closeModal);
          form.querySelector("[data-prev-step]")?.addEventListener("click", () => {
            currentFormData();
            step = Math.max(0, step - 1);
            renderStep();
          });
          form.querySelector("[data-next-step]")?.addEventListener("click", () => {
            currentFormData();
            const error = validateEventDraft(draft, step);
            if (error) {
              document.getElementById("eventError").textContent = error;
              return;
            }
            step = Math.min(steps.length - 1, step + 1);
            renderStep();
          });
          form.querySelector("[data-time-mode]")?.addEventListener("change", (event) => {
            const fixed = form.querySelector("[data-fixed-fields]");
            const windowFields = form.querySelector("[data-window-fields]");
            fixed.hidden = event.target.value !== "fixed";
            windowFields.hidden = event.target.value !== "window";
          });
        }

        form.addEventListener("submit", (event) => {
          event.preventDefault();
          currentFormData();
          const error = validateEventDraft(draft, 7);
          if (error) {
            document.getElementById("eventError").textContent = error;
            return;
          }
          const index = state.data.events.findIndex((item) => item.id === draft.id);
          const next = normalizeEvent(draft);
          if (index >= 0) state.data.events[index] = next;
          else state.data.events.push(next);
          saveData("Impegno salvato");
          closeModal();
          render();
        });

        renderStep();
      }

      function validateEventDraft(event, step) {
        if (step >= 0 && !event.title) return "Inserisci un titolo.";
        if (step >= 1 && !event.childIds.length) return "Seleziona almeno un figlio.";
        if (step >= 2) {
          if (event.eventType === "single" && !event.date) return "Inserisci la data.";
          if (event.eventType !== "single" && !event.startDate) return "Inserisci la data di inizio.";
          if (event.eventType !== "single" && !event.weekdays.length) return "Seleziona almeno un giorno.";
          if (event.endDate && event.endDate < event.startDate) return "La data di fine deve essere successiva all'inizio.";
        }
        return "";
      }

      function linesToItems(text, prefix) {
        return text.split(/\r?\n/).map((line) => line.trim()).filter(Boolean).map((label) => ({
          id: uid(prefix),
          label
        }));
      }

      function parseClosures(text) {
        return text.split(/\r?\n/).map((line) => line.trim()).filter(Boolean).map((line) => {
          const [datePart, reason = ""] = line.split("|");
          if (datePart.includes("..")) {
            const [startDate, endDate] = datePart.split("..").map((part) => part.trim());
            return { id: uid("closure"), type: "range", date: "", startDate, endDate, reason: reason.trim() };
          }
          return { id: uid("closure"), type: "date", date: datePart.trim(), startDate: "", endDate: "", reason: reason.trim() };
        });
      }

      function formatClosures(closures) {
        return closures.map((closure) => {
          const date = closure.type === "range" ? `${closure.startDate}..${closure.endDate}` : closure.date;
          return `${date}|${closure.reason || ""}`;
        }).join("\n");
      }

      function parseExceptions(text) {
        return text.split(/\r?\n/).map((line) => line.trim()).filter(Boolean).map((line) => {
          const [date, mode = "", note = ""] = line.split("|").map((part) => part.trim());
          if (mode.toLowerCase() === "annullato" || mode.toLowerCase() === "cancelled") {
            return { id: uid("exception"), date, type: "cancelled", fixedTime: null, timeWindow: null, note };
          }
          const [start, end] = mode.split("-").map((part) => part.trim());
          return { id: uid("exception"), date, type: "modified_time", fixedTime: { start: start || "", end: end || "" }, timeWindow: null, note };
        });
      }

      function formatExceptions(exceptions) {
        return exceptions.map((exception) => {
          const mode = exception.type === "cancelled" ? "annullato" : `${exception.fixedTime?.start || ""}-${exception.fixedTime?.end || ""}`;
          return `${exception.date}|${mode}|${exception.note || ""}`;
        }).join("\n");
      }

      function toggleChild(id) {
        const child = childById(id);
        if (!child) return;
        child.archived = !child.archived;
        saveData(child.archived ? "Figlio archiviato" : "Figlio riattivato");
        render();
      }

      function duplicateEvent(id) {
        const event = state.data.events.find((item) => item.id === id);
        if (!event) return;
        const copy = normalizeEvent(JSON.parse(JSON.stringify(event)));
        copy.id = uid("event");
        copy.title = `${copy.title} (copia)`;
        state.data.events.push(copy);
        saveData("Impegno duplicato");
        render();
      }

      function toggleEvent(id) {
        const event = state.data.events.find((item) => item.id === id);
        if (!event) return;
        event.archived = !event.archived;
        saveData(event.archived ? "Impegno archiviato" : "Impegno riattivato");
        render();
      }

      function deleteEvent(id) {
        const event = state.data.events.find((item) => item.id === id);
        if (!event) return;
        if (!confirm(`Eliminare "${event.title}"?`)) return;
        state.data.events = state.data.events.filter((item) => item.id !== id);
        saveData("Impegno eliminato");
        render();
      }

      function showToast(message) {
        els.toast.textContent = message;
        els.toast.classList.add("show");
        clearTimeout(showToast.timer);
        showToast.timer = setTimeout(() => els.toast.classList.remove("show"), 2200);
      }

      document.getElementById("quickAddEvent").addEventListener("click", () => openEventForm());
      document.getElementById("quickAddChild").addEventListener("click", () => openChildForm());
      els.modalClose.addEventListener("click", closeModal);
      els.modal.addEventListener("click", (event) => {
        if (event.target === els.modal) closeModal();
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && els.modal.classList.contains("open")) closeModal();
        trapModalFocus(event);
      });

      window.__agendaFigliTest = {
        makeSampleData,
        migrateData,
        validateImportedData,
        occurrencesBetween: (start, end, data) => {
          const previous = state.data;
          if (data) state.data = migrateData(data);
          const result = occurrencesBetween(start, end);
          state.data = previous;
          return result.map((item) => ({
            eventId: item.eventId,
            title: item.event.title,
            date: item.date,
            childCount: item.event.childIds.length,
            time: timeLabel(item),
            changed: item.changed
          }));
        },
        STORAGE_KEY
      };

      render();
    })();
  </script>
</body>
</html>
