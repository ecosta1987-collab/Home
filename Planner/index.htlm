<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Agenda figli offline</title>
  <style>
    :root {
      --bg: #f7f8f6;
      --panel: #ffffff;
      --panel-soft: #eef6f3;
      --text: #1e2329;
      --muted: #5d6673;
      --line: #d8ded9;
      --focus: #0f766e;
      --primary: #0f766e;
      --primary-strong: #115e59;
      --danger: #b42318;
      --warning: #a15c07;
      --blue: #2563eb;
      --shadow: 0 12px 32px rgba(27, 42, 38, .10);
      --radius: 8px;
      --tap: 44px;
    }

    * { box-sizing: border-box; }
    html { color-scheme: light; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.45;
    }

    button, input, select, textarea {
      font: inherit;
    }

    button, a, input, select, textarea, summary {
      outline-offset: 3px;
    }

    :focus-visible {
      outline: 3px solid color-mix(in srgb, var(--focus) 70%, white);
      outline-offset: 3px;
    }

    .app-shell {
      min-height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 30;
      background: rgba(247, 248, 246, .96);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(10px);
    }

    .topbar-inner {
      max-width: 1180px;
      margin: 0 auto;
      padding: 14px 18px 10px;
      display: grid;
      gap: 12px;
    }

    .brand-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
    }

    .brand-mark {
      width: 38px;
      height: 38px;
      border-radius: var(--radius);
      display: grid;
      place-items: center;
      background: #163b36;
      color: white;
      font-weight: 800;
    }

    h1, h2, h3, p { margin-top: 0; }
    h1 {
      margin-bottom: 0;
      font-size: clamp(1.25rem, 2.2vw, 1.75rem);
      letter-spacing: 0;
    }
    .subtitle {
      margin: 2px 0 0;
      color: var(--muted);
      font-size: .95rem;
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .tabs {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 4px;
    }

    .tab {
      min-height: 40px;
      border: 1px solid var(--line);
      background: var(--panel);
      color: var(--text);
      border-radius: var(--radius);
      padding: 8px 12px;
      cursor: pointer;
      white-space: nowrap;
    }

    .tab[aria-selected="true"] {
      background: #163b36;
      border-color: #163b36;
      color: white;
      font-weight: 700;
    }

    main {
      max-width: 1180px;
      width: 100%;
      margin: 0 auto;
      padding: 22px 18px 52px;
    }

    .view-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 16px;
    }

    .view-head h2 {
      margin-bottom: 4px;
      font-size: clamp(1.35rem, 2.4vw, 2rem);
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .section {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 16px;
      box-shadow: var(--shadow);
    }

    .section.unframed {
      background: transparent;
      border: 0;
      box-shadow: none;
      padding: 0;
    }

    .section h3 {
      margin-bottom: 10px;
      font-size: 1.05rem;
    }

    .stack { display: grid; gap: 10px; }
    .row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .row.spread { justify-content: space-between; }

    .button {
      min-height: var(--tap);
      border: 1px solid transparent;
      border-radius: var(--radius);
      padding: 9px 13px;
      background: var(--primary);
      color: white;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      text-decoration: none;
    }

    .button:hover { background: var(--primary-strong); }
    .button.secondary {
      background: var(--panel);
      color: var(--text);
      border-color: var(--line);
    }
    .button.secondary:hover { background: #eef2ef; }
    .button.danger {
      background: var(--danger);
      color: white;
    }
    .button.warning {
      background: #fff7ed;
      color: #873c00;
      border-color: #fed7aa;
    }
    .button.small {
      min-height: 36px;
      padding: 6px 10px;
      font-size: .92rem;
    }

    .filters {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: end;
      margin-bottom: 14px;
    }

    label {
      display: grid;
      gap: 5px;
      color: var(--text);
      font-weight: 650;
      font-size: .94rem;
    }

    input, select, textarea {
      min-height: 42px;
      width: 100%;
      border: 1px solid #c8d0cb;
      border-radius: var(--radius);
      background: white;
      color: var(--text);
      padding: 9px 10px;
    }

    textarea {
      min-height: 96px;
      resize: vertical;
    }

    input[type="checkbox"], input[type="radio"] {
      width: 18px;
      min-height: 18px;
      accent-color: var(--primary);
    }

    .choice-list {
      display: grid;
      gap: 8px;
    }

    .checkline {
      display: flex;
      align-items: center;
      gap: 8px;
      min-height: 36px;
      font-weight: 500;
    }

    .empty {
      border: 1px dashed #b9c3bd;
      border-radius: var(--radius);
      padding: 18px;
      color: var(--muted);
      background: #fbfcfb;
    }

    .event-card {
      background: white;
      border: 1px solid var(--line);
      border-left: 6px solid var(--primary);
      border-radius: var(--radius);
      padding: 13px;
      display: grid;
      gap: 9px;
    }

    .event-card.archived,
    .child-card.archived {
      opacity: .68;
      background: #f5f5f4;
    }

    .event-title {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
    }

    .event-title h3 {
      margin: 0;
      font-size: 1.05rem;
    }

    .meta {
      color: var(--muted);
      font-size: .94rem;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 28px;
      padding: 4px 8px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: #f7faf8;
      color: #25312d;
      font-size: .86rem;
      font-weight: 650;
      white-space: nowrap;
    }

    .child-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 30px;
      border-radius: 999px;
      padding: 4px 8px;
      color: #111827;
      background: #f3f4f6;
      border: 1px solid var(--line);
      font-weight: 700;
    }

    .avatar {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      display: inline-grid;
      place-items: center;
      color: white;
      font-size: .78rem;
      font-weight: 800;
      flex: 0 0 auto;
    }

    .day-group {
      display: grid;
      gap: 10px;
      margin-bottom: 18px;
    }

    .day-title {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #26332f;
      border-bottom: 1px solid var(--line);
      padding-bottom: 8px;
      margin: 0;
    }

    .child-card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 14px;
      display: grid;
      gap: 10px;
    }

    .status-dot {
      width: 12px;
      height: 12px;
      border-radius: 999px;
      display: inline-block;
    }

    details.advanced {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: #fbfcfb;
      padding: 8px 10px;
    }

    details.advanced > summary {
      cursor: pointer;
      font-weight: 750;
      min-height: 34px;
      display: flex;
      align-items: center;
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 80;
      background: rgba(13, 24, 22, .48);
      display: none;
      align-items: stretch;
      justify-content: flex-end;
    }

    .modal-backdrop.open { display: flex; }

    .panel {
      width: min(720px, 100%);
      background: var(--panel);
      min-height: 100%;
      overflow: auto;
      box-shadow: -20px 0 50px rgba(0, 0, 0, .20);
      padding: 18px;
    }

    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 16px;
      position: sticky;
      top: 0;
      background: var(--panel);
      padding-bottom: 10px;
      z-index: 1;
    }

    .steps {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    .step-chip {
      min-height: 30px;
      border: 1px solid var(--line);
      background: #f7faf8;
      border-radius: 999px;
      padding: 4px 8px;
      color: var(--muted);
      font-size: .85rem;
    }

    .step-chip.active {
      background: #163b36;
      color: white;
      border-color: #163b36;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .form-grid .full { grid-column: 1 / -1; }

    .inline-error {
      color: var(--danger);
      font-size: .9rem;
      font-weight: 650;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%);
      z-index: 90;
      background: #163b36;
      color: white;
      border-radius: var(--radius);
      padding: 10px 14px;
      box-shadow: var(--shadow);
      min-width: min(380px, calc(100vw - 28px));
      text-align: center;
      display: none;
    }

    .toast.show { display: block; }

    .data-box {
      border: 1px solid var(--line);
      background: #fbfcfb;
      border-radius: var(--radius);
      padding: 12px;
      overflow: auto;
      max-height: 260px;
      white-space: pre-wrap;
      font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
      font-size: .86rem;
    }

    .packing-list {
      display: grid;
      gap: 7px;
      padding-top: 2px;
    }

    .week-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 14px;
      flex-wrap: wrap;
    }

    @media (max-width: 860px) {
      .grid-3, .grid-2, .form-grid {
        grid-template-columns: 1fr;
      }
      .brand-row, .view-head {
        align-items: stretch;
        flex-direction: column;
      }
      .actions {
        justify-content: stretch;
      }
      .actions .button {
        flex: 1 1 160px;
      }
      .panel {
        width: 100%;
      }
    }

    @media (max-width: 520px) {
      .topbar-inner, main { padding-left: 12px; padding-right: 12px; }
      .tabs { gap: 6px; }
      .tab { padding: 8px 10px; }
      .section { padding: 13px; }
      .event-title { display: grid; }
      .button { width: 100%; }
      .row .button { width: auto; }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <header class="topbar">
      <div class="topbar-inner">
        <div class="brand-row">
          <div class="brand">
            <div class="brand-mark" aria-hidden="true">AF</div>
            <div>
              <h1>Agenda figli offline</h1>
              <p class="subtitle">Impegni condivisi, chiari, salvati su questo dispositivo.</p>
            </div>
          </div>
          <div class="actions">
            <button class="button" id="quickAddEvent" type="button">+ Aggiungi impegno</button>
            <button class="button secondary" id="quickAddChild" type="button">+ Aggiungi figlio</button>
          </div>
        </div>
        <nav class="tabs" aria-label="Schermate principali" id="tabs"></nav>
      </div>
    </header>
    <main id="app" tabindex="-1"></main>
  </div>

  <div class="modal-backdrop" id="modalBackdrop" aria-hidden="true">
    <section class="panel" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="panel-head">
        <div>
          <h2 id="modalTitle">Modifica</h2>
          <p class="subtitle" id="modalSubtitle"></p>
        </div>
        <button class="button secondary small" id="modalClose" type="button">Chiudi</button>
      </div>
      <div id="modalBody"></div>
    </section>
  </div>
  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <script>
    (() => {
      "use strict";

      const SCHEMA_VERSION = 1;
      const STORAGE_KEY = "agenda_figli_offline_v1";
      const WEEKDAYS = [
        { value: 1, short: "Lun", long: "Lunedì" },
        { value: 2, short: "Mar", long: "Martedì" },
        { value: 3, short: "Mer", long: "Mercoledì" },
        { value: 4, short: "Gio", long: "Giovedì" },
        { value: 5, short: "Ven", long: "Venerdì" },
        { value: 6, short: "Sab", long: "Sabato" },
        { value: 0, short: "Dom", long: "Domenica" }
      ];
      const CATEGORIES = ["scuola", "sport", "centro estivo", "festa", "appuntamento", "altro"];
      const EVENT_TYPES = [
        { value: "single", label: "Singolo" },
        { value: "recurring", label: "Ricorrente" },
        { value: "continuous", label: "Continuativo" }
      ];
      const MEALS = [
        { value: "mensa", label: "Mensa" },
        { value: "merenda inclusa", label: "Merenda inclusa" },
        { value: "pranzo al sacco", label: "Pranzo al sacco" }
      ];

      const state = {
        data: loadData(),
        view: "home",
        weekStart: startOfWeek(new Date()),
        filters: { childId: "all", category: "all", eventType: "all" },
        tempChecklist: {},
        lastFocus: null
      };

      const els = {
        app: document.getElementById("app"),
        tabs: document.getElementById("tabs"),
        modal: document.getElementById("modalBackdrop"),
        modalTitle: document.getElementById("modalTitle"),
        modalSubtitle: document.getElementById("modalSubtitle"),
        modalBody: document.getElementById("modalBody"),
        modalClose: document.getElementById("modalClose"),
        toast: document.getElementById("toast")
      };

      const VIEWS = [
        { id: "home", label: "Home" },
        { id: "week", label: "Settimana" },
        { id: "agenda", label: "Agenda" },
        { id: "children", label: "Figli" },
        { id: "events", label: "Impegni" },
        { id: "data", label: "Dati" }
      ];

      function uid(prefix) {
        return `${prefix}_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 8)}`;
      }

      function todayISO() {
        return toISODate(new Date());
      }

      function toISODate(date) {
        const copy = new Date(date);
        copy.setHours(0, 0, 0, 0);
        const year = copy.getFullYear();
        const month = String(copy.getMonth() + 1).padStart(2, "0");
        const day = String(copy.getDate()).padStart(2, "0");
        return `${year}-${month}-${day}`;
      }

      function parseISODate(value) {
        if (!value) return null;
        const [y, m, d] = value.split("-").map(Number);
        if (!y || !m || !d) return null;
        return new Date(y, m - 1, d);
      }

      function addDays(date, days) {
        const copy = new Date(date);
        copy.setDate(copy.getDate() + days);
        return copy;
      }

      function startOfWeek(date) {
        const copy = new Date(date);
        copy.setHours(0, 0, 0, 0);
        const day = copy.getDay();
        const diff = day === 0 ? -6 : 1 - day;
        return addDays(copy, diff);
      }

      function formatDate(value, options = {}) {
        const date = typeof value === "string" ? parseISODate(value) : value;
        if (!date) return "";
        return new Intl.DateTimeFormat("it-IT", {
          weekday: options.weekday ? "long" : undefined,
          day: "2-digit",
          month: "short",
          year: options.year ? "numeric" : undefined
        }).format(date);
      }

      function escapeHtml(value) {
        return String(value ?? "").replace(/[&<>"']/g, (char) => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;"
        }[char]));
      }

      function normalizeColor(value, fallback = "#0f766e") {
        return /^#[0-9a-f]{6}$/i.test(value || "") ? value : fallback;
      }

      function createEmptyData() {
        return {
          schemaVersion: SCHEMA_VERSION,
          exportedAt: null,
          settings: { weekStartsOn: 1 },
          children: [],
          events: [],
          lastSavedAt: null
        };
      }

      function migrateData(raw) {
        const base = createEmptyData();
        if (!raw || typeof raw !== "object") return base;
        const migrated = {
          ...base,
          ...raw,
          schemaVersion: SCHEMA_VERSION,
          settings: { ...base.settings, ...(raw.settings || {}) },
          children: Array.isArray(raw.children) ? raw.children : [],
          events: Array.isArray(raw.events) ? raw.events : []
        };
        migrated.children = migrated.children.map((child) => ({
          id: String(child.id || uid("child")),
          name: String(child.name || "Senza nome"),
          color: normalizeColor(child.color),
          avatar: String(child.avatar || child.name?.[0] || "?").slice(0, 2),
          notes: String(child.notes || ""),
          archived: Boolean(child.archived)
        }));
        migrated.events = migrated.events.map(normalizeEvent);
        return migrated;
      }

      function normalizeEvent(event) {
        const eventType = ["single", "recurring", "continuous"].includes(event.eventType) ? event.eventType : "single";
        const category = CATEGORIES.includes(event.category) ? event.category : "altro";
        const timeMode = event.timeMode === "window" ? "window" : "fixed";
        const fixedTime = event.fixedTime && typeof event.fixedTime === "object"
          ? { start: String(event.fixedTime.start || ""), end: String(event.fixedTime.end || "") }
          : { start: "", end: "" };
        const timeWindow = event.timeWindow && typeof event.timeWindow === "object"
          ? {
              entryStart: String(event.timeWindow.entryStart || ""),
              entryEnd: String(event.timeWindow.entryEnd || ""),
              exitStart: String(event.timeWindow.exitStart || ""),
              exitEnd: String(event.timeWindow.exitEnd || "")
            }
          : { entryStart: "", entryEnd: "", exitStart: "", exitEnd: "" };
        return {
          id: String(event.id || uid("event")),
          title: String(event.title || "Impegno senza titolo"),
          category,
          eventType,
          childIds: Array.isArray(event.childIds) ? event.childIds.map(String) : [],
          location: String(event.location || ""),
          date: String(event.date || event.startDate || todayISO()),
          startDate: String(event.startDate || event.date || todayISO()),
          endDate: String(event.endDate || ""),
          weekdays: Array.isArray(event.weekdays) ? event.weekdays.map(Number).filter((d) => d >= 0 && d <= 6) : [],
          timeMode,
          fixedTime: timeMode === "fixed" ? fixedTime : null,
          timeWindow: timeMode === "window" ? timeWindow : null,
          mealOptions: Array.isArray(event.mealOptions) ? event.mealOptions.map(String) : [],
          notes: String(event.notes || ""),
          packingList: Array.isArray(event.packingList)
            ? event.packingList.map((item) => ({ id: String(item.id || uid("item")), label: String(item.label || "") })).filter((item) => item.label)
            : [],
          closures: Array.isArray(event.closures) ? event.closures.map(normalizeClosure).filter(Boolean) : [],
          exceptions: Array.isArray(event.exceptions) ? event.exceptions.map(normalizeException).filter(Boolean) : [],
          archived: Boolean(event.archived)
        };
      }

      function normalizeClosure(closure) {
        if (!closure || typeof closure !== "object") return null;
        const type = closure.type === "range" ? "range" : "date";
        return {
          id: String(closure.id || uid("closure")),
          type,
          date: String(closure.date || ""),
          startDate: String(closure.startDate || ""),
          endDate: String(closure.endDate || ""),
          reason: String(closure.reason || "")
        };
      }

      function normalizeException(exception) {
        if (!exception || typeof exception !== "object") return null;
        const type = exception.type === "cancelled" ? "cancelled" : "modified_time";
        return {
          id: String(exception.id || uid("exception")),
          date: String(exception.date || ""),
          type,
          fixedTime: exception.fixedTime ? {
            start: String(exception.fixedTime.start || ""),
            end: String(exception.fixedTime.end || "")
          } : null,
          timeWindow: exception.timeWindow ? {
            entryStart: String(exception.timeWindow.entryStart || ""),
            entryEnd: String(exception.timeWindow.entryEnd || ""),
            exitStart: String(exception.timeWindow.exitStart || ""),
            exitEnd: String(exception.timeWindow.exitEnd || "")
          } : null,
          note: String(exception.note || "")
        };
      }

      function loadData() {
        try {
          const stored = localStorage.getItem(STORAGE_KEY);
          if (!stored) return createEmptyData();
          return migrateData(JSON.parse(stored));
        } catch (error) {
          console.warn("Dati locali non leggibili. Uso un archivio vuoto.", error);
          return createEmptyData();
        }
      }

      function saveData(message = "Salvato") {
        state.data.lastSavedAt = new Date().toISOString();
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state.data));
        if (message) showToast(message);
      }

      function validateImportedData(candidate) {
        const errors = [];
        if (!candidate || typeof candidate !== "object") errors.push("Il file deve contenere un oggetto JSON.");
        if (!Number.isInteger(candidate?.schemaVersion)) errors.push("Manca schemaVersion numerico.");
        if (!Array.isArray(candidate?.children)) errors.push("children deve essere un array.");
        if (!Array.isArray(candidate?.events)) errors.push("events deve essere un array.");
        const childIds = new Set();
        (candidate?.children || []).forEach((child, index) => {
          if (!child.id) errors.push(`Figlio ${index + 1}: manca id.`);
          if (!child.name) errors.push(`Figlio ${index + 1}: manca nome.`);
          if (child.id && childIds.has(child.id)) errors.push(`Id figlio duplicato: ${child.id}.`);
          childIds.add(child.id);
        });
        (candidate?.events || []).forEach((event, index) => {
          if (!event.id) errors.push(`Impegno ${index + 1}: manca id.`);
          if (!event.title) errors.push(`Impegno ${index + 1}: manca titolo.`);
          if (!["single", "recurring", "continuous"].includes(event.eventType)) errors.push(`Impegno ${index + 1}: tipologia non valida.`);
          if (!Array.isArray(event.childIds)) errors.push(`Impegno ${index + 1}: childIds deve essere un array.`);
          (event.childIds || []).forEach((childId) => {
            if (!childIds.has(childId)) errors.push(`Impegno "${event.title || index + 1}": figlio non trovato (${childId}).`);
          });
        });
        return { ok: errors.length === 0, errors };
      }

      function exportPayload(data = state.data) {
        return {
          schemaVersion: SCHEMA_VERSION,
          exportedAt: new Date().toISOString(),
          settings: data.settings,
          children: data.children,
          events: data.events
        };
      }

      function downloadJSON(filename, payload) {
        const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }

      function makeSampleData() {
        const children = [
          { id: "child_anna", name: "Anna", color: "#0f766e", avatar: "A", notes: "Ama sapere il piano in anticipo.", archived: false },
