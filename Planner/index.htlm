            date: "2026-07-25",
            startDate: "2026-07-25",
            endDate: "",
            weekdays: [],
            timeMode: "fixed",
            fixedTime: { start: "16:00", end: "18:30" },
            timeWindow: null,
            mealOptions: ["merenda inclusa"],
