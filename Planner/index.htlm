            mealOptions: ["pranzo al sacco"],
            notes: "Crema solare già applicata al mattino.",
            packingList: [
              { id: "item_estivo_1", label: "Cappellino" },
              { id: "item_estivo_2", label: "Crema solare" },
              { id: "item_estivo_3", label: "Pranzo al sacco" },
              { id: "item_estivo_4", label: "Borraccia" }
            ],
            closures: [{ id: "closure_estivo_1", type: "date", date: "2026-07-31", startDate: "", endDate: "", reason: "Gita annullata: centro chiuso" }],
            exceptions: [{ id: "exception_estivo_1", date: "2026-07-24", type: "modified_time", fixedTime: { start: "08:30", end: "13:00" }, timeWindow: null, note: "Uscita anticipata" }],
